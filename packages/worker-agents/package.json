{
  "name": "@workshop/worker-agents",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "worker-agents — the same agent, offloaded to background workers via a Valkey queue.",
  "scripts": {
    "web": "node --env-file-if-exists=../../.env --env-file-if-exists=.env --import tsx src/web.ts",
    "worker": "node --env-file-if-exists=../../.env --env-file-if-exists=.env --import tsx src/worker.ts",
    "start": "node --import tsx src/web.ts",
    "start:worker": "node --import tsx src/worker.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@workshop/agent": "*",
    "@workshop/db": "*",
    "@workshop/ui": "*",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1"
  }
}
