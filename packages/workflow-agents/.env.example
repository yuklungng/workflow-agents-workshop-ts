# --- Local development ---
# Host npm run dev: in-process shortcut (RENDER_USE_LOCAL_DEV=true, no URL below).
# Host npm run dev:workflows / Docker Pattern 3: SDK → Render CLI dev server on :8120.
RENDER_USE_LOCAL_DEV=true
# RENDER_LOCAL_DEV_URL=http://127.0.0.1:8120   # set by Docker Compose; uncomment for host dev:workflows
# RENDER_API_KEY=local-dev                      # dummy token for local dev server (Docker sets this)

# --- Agent LLM calls (optional — agents fall back to a mock model when unset) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Telemetry store (optional locally — falls back to in-memory; auto-wired on Render) ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/workflow_agents

# --- API auth (optional — open access when unset) ---
# Generate a key: openssl rand -hex 32
# WORKFLOW_API_KEY=your-secret-key   # Protects POST /api/reviews and /webhooks/*

# --- Production only ---
# RENDER_API_KEY=rnd_...
# GITHUB_WEBHOOK_SECRET=whsec_...
# GITHUB_TOKEN=ghp_...               # raises GitHub API rate limits / private repo diffs
